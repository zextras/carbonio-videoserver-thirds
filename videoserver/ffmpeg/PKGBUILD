pkgname="carbonio-ffmpeg"
pkgver="8.1" # renovate: datasource=github-releases depName=FFmpeg/FFmpeg
pkgrel="1"
pkgdesc="Complete solution to record, convert and stream audio and video"
arch=('aarch64' 'x86_64')
maintainer="Zextras <packages@zextras.com"
url="https://zextras.com"
depends__apt=(
  "carbonio-libopus"
  "carbonio-libvpx"
  "carbonio-x264"
  "libc6"
  "zlib1g"
)
depends__yum=(
  "carbonio-libopus"
  "carbonio-libvpx"
  "carbonio-x264"
  "zlib"
)
makedepends__apt=(
  "nasm"
  "pkg-config"
  "zlib1g-dev"
)
makedepends__yum=(
  "nasm"
  "pkgconf-pkg-config"
  "zlib-devel"
)
section="libs"
priority="important"
source=(
  "https://ffmpeg.org/releases/ffmpeg-${pkgver}.tar.gz"
)
sha256sums=('b13510e7a6a4ca28fa04307f2be54ef5a31e168eb2bbe055a7f4e4d2cadd51b1')

build() {
  cd "${srcdir}/ffmpeg-${pkgver}"
  export CFLAGS="${CFLAGS} -ffile-prefix-map=${srcdir}=."
  export LDFLAGS="-Wl,-rpath,/opt/zextras/common/lib"
  export PKG_CONFIG_PATH="/opt/zextras/common/lib/pkgconfig:/opt/zextras/common/lib64/pkgconfig"

  _cross_flags=""
  if [ -n "${CROSS_COMPILE}" ] && echo "${CROSS_COMPILE}" | grep -q "aarch64"; then
    _cross_flags="--enable-cross-compile --cross-prefix=${CROSS_COMPILE} --arch=aarch64 --target-os=linux"
  fi

  ./configure \
    --bindir="/opt/zextras/common/bin" \
    --pkg-config=pkg-config \
    --disable-debug \
    --disable-static \
    --disable-stripping \
    --enable-gpl \
    --enable-libopus \
    --enable-libvpx \
    --enable-libx264 \
    --enable-shared \
    --extra-cflags="-I/opt/zextras/common/include" \
    --extra-ldflags="-L/opt/zextras/common/lib" \
    --prefix=/opt/zextras/common \
    ${_cross_flags}
  make -j"$(($(nproc) / 2))"
}

package() {
  cd "${srcdir}/ffmpeg-${pkgver}"
  make DESTDIR="${pkgdir}" install
  rm -rf "${pkgdir}"/opt/zextras/common/share
}
