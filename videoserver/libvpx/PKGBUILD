pkgname="carbonio-libvpx"
pkgver="1.16.0" # renovate: datasource=github-releases depName=webmproject/libvpx
pkgrel="1"
pkgdesc="VP8 and VP9 codec"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com"
url="https://zextras.com"
makedepends=(
  "nasm"
)
section="libs"
priority="important"
source=(
  "https://github.com/webmproject/libvpx/archive/v${pkgver}.tar.gz"
)
sha256sums=('7a479a3c66b9f5d5542a4c6a1b7d3768a983b1e5c14c60a9396edc9b649e015c')

build() {
  cd "${srcdir}/libvpx-${pkgver}"
  export CFLAGS="${CFLAGS} -ffile-prefix-map=${srcdir}=."
  export CXXFLAGS="${CXXFLAGS} -ffile-prefix-map=${srcdir}=."
  export LDFLAGS="-Wl,-rpath,/opt/zextras/common/lib"

  ./configure \
    --as=nasm \
    --disable-install-docs \
    --disable-install-srcs \
    --enable-pic \
    --enable-postproc \
    --enable-runtime-cpu-detect \
    --enable-shared \
    --enable-vp8 \
    --enable-vp9 \
    --enable-vp9-highbitdepth \
    --enable-vp9-temporal-denoising \
    --prefix=/opt/zextras/common
  make -j"$(( $(nproc) / 2 ))"
}

package() {
  cd "${srcdir}/libvpx-${pkgver}"
  make DIST_DIR="${pkgdir}/opt/zextras/common" install
  rm -rf "${pkgdir}"/opt/zextras/common/lib/*.a
  rm -rf "${pkgdir}"/opt/zextras/common/lib/*.la
}
