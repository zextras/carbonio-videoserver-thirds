pkgname="carbonio-libfdk-aac"
pkgver="2.0.3" # renovate: datasource=github-releases depName=mstorsjo/fdk-aac
pkgrel="1"
pkgdesc="Fraunhofer FDK AAC codec library"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com"
url="https://zextras.com"
makedepends__apt=(
  "autoconf"
  "automake"
  "libtool-bin"
)
makedepends__yum=(
  "autoconf"
  "automake"
  "libtool"
)
section="libs"
priority="important"
source=(
  "https://github.com/mstorsjo/fdk-aac/archive/v${pkgver}.tar.gz"
)
sha256sums=('e25671cd96b10bad896aa42ab91a695a9e573395262baed4e4a2ff178d6a3a78')

build() {
  cd "${srcdir}/fdk-aac-${pkgver}"
  export CFLAGS="${CFLAGS} -ffile-prefix-map=${srcdir}=."
  export CXXFLAGS="${CXXFLAGS} -ffile-prefix-map=${srcdir}=."
  export LDFLAGS="-Wl,-rpath,/opt/zextras/common/lib"

  ./autogen.sh
  ./configure \
    --prefix=/opt/zextras/common \
    --disable-static
  make -j"$(( $(nproc) / 2 ))"
}

package() {
  cd "${srcdir}/fdk-aac-${pkgver}"
  make DESTDIR="${pkgdir}" install
  rm -rf "${pkgdir}"/opt/zextras/common/lib/*.la
}
