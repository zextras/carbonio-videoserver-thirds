pkgname="carbonio-libopus"
pkgver="1.6.1" # renovate: datasource=repology depName=opus
pkgrel="1"
pkgdesc="Totally open, royalty-free, highly versatile audio codec"
arch=('aarch64' 'x86_64')
maintainer="Zextras <packages@zextras.com"
url="https://zextras.com"
section="libs"
priority="important"
makedepends=(
  "autoconf"
  "automake"
  "libtool"
)
source=(
  "https://downloads.xiph.org/releases/opus/opus-${pkgver}.tar.gz"
)
sha256sums=('6ffcb593207be92584df15b32466ed64bbec99109f007c82205f0194572411a1')

build() {
  cd "${srcdir}/opus-${pkgver}"
  export CFLAGS="${CFLAGS} -ffile-prefix-map=${srcdir}=."
  export LDFLAGS="-Wl,-rpath,/opt/zextras/common/lib"
  export PKG_CONFIG_PATH="/opt/zextras/common/lib/pkgconfig:/opt/zextras/common/lib64/pkgconfig"

  _host_flag=""
  _build_flag=""
  if [ -n "${CROSS_COMPILE}" ]; then
    export CC="${CROSS_COMPILE}gcc"
    export CXX="${CROSS_COMPILE}g++"
    export AR="${CROSS_COMPILE}ar"
    export RANLIB="${CROSS_COMPILE}ranlib"
    _host_flag="--host=${CROSS_COMPILE_HOST}"
    _build_flag="--build=$(gcc -dumpmachine)"
  fi

  autoreconf -fi
  ./configure \
    --disable-static \
    --libdir=/opt/zextras/common/lib \
    --prefix=/opt/zextras/common \
    ${_host_flag} ${_build_flag}
  make -j"$(($(nproc) / 2))"
}

package() {
  cd "${srcdir}/opus-${pkgver}"
  make DESTDIR="${pkgdir}" install
  rm -rf "${pkgdir}"/opt/zextras/common/lib/*.la
}
